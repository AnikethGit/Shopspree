# Copy this file to config/.env and fill in your values.
# config/.env is gitignored and must never be committed.

# Database (Hostinger: cPanel > Databases > MySQL Databases)
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASS=

# Application
APP_ENV=production
# development  →  shows errors on screen
# production   →  logs errors only (never shows to users)

SITE_URL=https://printdepotco.com/
SITE_NAME=PrintDepotCo
SITE_EMAIL=noreply@printdepotco.com
SITE_PHONE=+1-234-567-8900
ADMIN_EMAIL=admin@printdepotco.com

# Business settings
COMPANY_ADDRESS=123 Street, New York, USA
FREE_SHIPPING_THRESHOLD=100.00
GIFT_CARD_THRESHOLD=50.00
TAX_RATE=0.06

# Social media (leave blank to hide icons in footer)
SOCIAL_TWITTER=
SOCIAL_FACEBOOK=
SOCIAL_YOUTUBE=
SOCIAL_LINKEDIN=
