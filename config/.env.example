# Copy this file to config/.env and fill in your values.
# config/.env is gitignored and must never be committed.

# Database (Hostinger: cPanel > Databases > MySQL Databases)
DB_HOST=localhost
DB_NAME=
DB_USER=
DB_PASS=

# Application
APP_ENV=production
# development  →  shows errors on screen
# production   →  logs errors only (never shows to users)

SITE_URL=https://printdepotco.com/
ADMIN_EMAIL=admin@printdepotco.com
